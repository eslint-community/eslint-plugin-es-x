{
  "name": "eslint-plugin-es-x",
  "version": "9.5.0",
  "description": "ESLint plugin about ECMAScript syntactic features.",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "main": "dist/index.js",
  "files": [
    "dist"
  ],
  "peerDependencies": {
    "eslint": ">=9.29.0"
  },
  "dependencies": {
    "@eslint-community/eslint-utils": "^4.1.2",
    "@eslint-community/regexpp": "^4.12.1",
    "eslint-type-tracer": "^0.5.1"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.2",
    "@clack/prompts": "^1.0.0",
    "@eslint-community/eslint-plugin-eslint-comments": "^4.6.0",
    "@oxc-node/core": "^0.0.35",
    "@svitejs/changesets-changelog-github-compact": "^1.2.0",
    "@typescript-eslint/parser": "^8.0.0",
    "c8": "^11.0.0",
    "env-cmd": "^11.0.0",
    "eslint": "^10.0.0",
    "eslint-plugin-eslint-plugin": "^7.0.0",
    "eslint-plugin-n": "^17.8.1",
    "eslint-plugin-prettier": "^5.0.0",
    "eslint-plugin-vue": "^10.0.0",
    "espree": "^11.0.0",
    "globals": "^17.0.0",
    "jsdom": "^29.0.0",
    "mocha": "^11.0.0",
    "monaco-editor": "^0.55.0",
    "npm-run-all2": "^8.0.0",
    "opener": "^1.5.1",
    "rimraf": "^6.0.0",
    "semver": "^7.0.0",
    "typescript": "^5.8.3",
    "vite-plugin-eslint4b": "^0.7.0",
    "vitepress": "^1.0.0",
    "vue-eslint-parser": "^10.0.0"
  },
  "scripts": {
    "prebuild": "npm run -s clean",
    "build": "tsc -p tsconfig.build.json",
    "clean": "rimraf .nyc_output dist coverage",
    "coverage": "c8 report --reporter=lcov && opener ./coverage/lcov-report/index.html",
    "docs:build": "vitepress build docs",
    "docs:watch": "vitepress dev docs",
    "lint": "eslint lib tests scripts eslint-internal docs/.vitepress",
    "lint:fix": "eslint lib tests scripts eslint-internal docs/.vitepress --fix",
    "new": "npm run -s ts -- scripts/new-rule",
    "pretest": "npm run -s lint",
    "test": "c8 npm run -s test:base",
    "test:base": "npm run -s mocha -- \"tests/**/*.{js,mjs}\" --reporter dot --timeout 60000",
    "test:ci": "c8 --reporter=lcovonly npm run -s test:base",
    "tsc": "tsc --noEmit",
    "ts": "node --import @oxc-node/core/register",
    "mocha": "npm run -s ts -- ./node_modules/mocha/bin/mocha.js",
    "update": "run-s update:*",
    "update:url": "npm run -s lint -- --fix",
    "update:configs": "npm run -s ts -- scripts/update-lib-configs",
    "update:flat-configs": "npm run -s ts -- scripts/update-lib-flat-configs",
    "update:index": "npm run -s ts -- scripts/update-lib-index",
    "update:doc": "npm run -s ts -- scripts/update-docs-readme",
    "update:rule-docs": "npm run -s ts -- scripts/update-docs-rules",
    "update:config-docs": "npm run -s ts -- scripts/update-docs-configs",
    "resource-update:unicode-properties": "npm run -s ts -- scripts/update-unicode-properties",
    "preversion": "npm test",
    "version": "npm run generate:version && git add .",
    "postversion": "git push && git push --tags",
    "watch": "npm run -s test:base -- --reporter progress --watch --growl",
    "generate:version": "env-cmd -e version -- run-s update:*",
    "changeset:version": "changeset version && npm run generate:version && git add --all",
    "changeset:publish": "npm run build && changeset publish"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eslint-community/eslint-plugin-es-x.git"
  },
  "keywords": [
    "eslint",
    "plugin",
    "eslintplugin"
  ],
  "author": "Toru Nagashima (https://github.com/mysticatea)",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/eslint-community/eslint-plugin-es-x/issues"
  },
  "homepage": "https://github.com/eslint-community/eslint-plugin-es-x#readme",
  "funding": [
    "https://github.com/sponsors/ota-meshi",
    "https://opencollective.com/eslint"
  ]
}
